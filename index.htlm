                    </div>

                    <div class="bg-rose-50/50 rounded-2xl sm:rounded-3xl p-5 sm:p-8 md:p-10 border border-rose-100 w-full min-w-0">
                        <h3 class="text-base sm:text-xl font-bold text-rose-800 mb-1.5 sm:mb-2 flex items-center"><span class="mr-1.5 sm:mr-2">⚠️</span> Опасная зона</h3>
                        <p class="text-[10px] sm:text-sm text-rose-600/80 mb-4 sm:mb-6">При выходе из аккаунта вы больше не сможете синхронизировать прогресс до повторного входа.</p>
                        <button id="btnProfileLogout" class="bg-white text-rose-600 border border-rose-200 rounded-xl px-4 sm:px-6 py-2.5 sm:py-3.5 text-xs sm:text-sm font-bold hover:bg-rose-50 transition-colors w-full sm:w-auto shadow-sm text-center">
                            Выйти из аккаунта
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </main>

    <script>
        // ЛОГИКА ДЛЯ МОБИЛЬНОГО МЕНЮ
        const sidebar = document.getElementById('sidebar');
        const mobileMenuBtn = document.getElementById('mobileMenuBtn');
        const sidebarOverlay = document.getElementById('sidebarOverlay');

        function toggleSidebar() {
            const isOpen = !sidebar.classList.contains('-translate-x-full');
            if (isOpen) {
                sidebar.classList.add('-translate-x-full');
                sidebarOverlay.classList.remove('opacity-100');
                sidebarOverlay.classList.add('opacity-0');
                setTimeout(() => sidebarOverlay.classList.add('hidden'), 300);
            } else {
                sidebarOverlay.classList.remove('hidden');
                setTimeout(() => {
                    sidebar.classList.remove('-translate-x-full');
                    sidebarOverlay.classList.remove('opacity-0');
                    sidebarOverlay.classList.add('opacity-100');
                }, 10);
            }
        }

        mobileMenuBtn.addEventListener('click', toggleSidebar);
        sidebarOverlay.addEventListener('click', toggleSidebar);

        // АВТОРЕСАЙЗ ТЕКСТОВЫХ ПОЛЕЙ
        function autoResizeTextarea(el) {
            el.style.height = 'auto';
            el.style.height = (el.scrollHeight) + 'px';
        }
        document.addEventListener('input', function(e) {
            if (e.target.classList.contains('auto-resize')) { autoResizeTextarea(e.target); }
        });
        function triggerResizeAll() {
            document.querySelectorAll('textarea.auto-resize').forEach(el => autoResizeTextarea(el));
        }

        // ОБРАБОТЧИКИ ЗАГРУЗКИ И УДАЛЕНИЯ ИЗОБРАЖЕНИЙ
        window.processImageUpload = function(event, callback) {
            const file = event.target.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = function(e) {
                const img = new Image();
                img.onload = function() {
                    const canvas = document.createElement('canvas');
                    const MAX_WIDTH = 600;
                    let width = img.width, height = img.height;
                    if (width > MAX_WIDTH) { height = Math.round((height * MAX_WIDTH) / width); width = MAX_WIDTH; }
                    canvas.width = width; canvas.height = height;
                    const ctx = canvas.getContext('2d');
                    ctx.drawImage(img, 0, 0, width, height);
                    callback(canvas.toDataURL('image/jpeg', 0.6));
                }
                img.src = e.target.result;
            }
            reader.readAsDataURL(file);
        };

        window.updateImageDOM = function(elementId, base64) {
            const el = document.getElementById(elementId);
            if(!el) return;
            if(base64) {
                el.style.backgroundImage = `url("${base64}")`;
                el.classList.add('has-image');
            } else {
                el.style.backgroundImage = `none`;
                el.classList.remove('has-image');
            }
        };

        window.uploadVisionImage = function(event, groupKey, slotIndex, elementId) {
            window.processImageUpload(event, (base64) => {
                window.appDataGlobal.vision.images[groupKey].slots[slotIndex] = base64;
                window.forceSaveGlobal();
                window.updateImageDOM(elementId, base64);
            });
        };

        window.deleteVisionImage = function(event, groupKey, slotIndex, elementId) {
            event.stopPropagation();
            event.preventDefault();
            window.appDataGlobal.vision.images[groupKey].slots[slotIndex] = '';
            window.forceSaveGlobal();
            window.updateImageDOM(elementId, '');
            document.getElementById(`up_${groupKey}_${slotIndex}`).value = ''; 
        };

        window.uploadRewardImage = function(event, blockIndex, tier, elementId) {
            window.processImageUpload(event, (base64) => {
                window.appDataGlobal.rewards[blockIndex][tier].image = base64;
                window.forceSaveGlobal();
                window.updateImageDOM(elementId, base64);
            });
        };

        window.deleteRewardImage = function(event, blockIndex, tier, elementId) {
            event.stopPropagation();
            event.preventDefault();
            window.appDataGlobal.rewards[blockIndex][tier].image = '';
            window.forceSaveGlobal();
            window.updateImageDOM(elementId, '');
            document.getElementById(`upRew_${tier}`).value = ''; 
        };

        document.addEventListener('DOMContentLoaded', () => {

            // ИНИЦИАЛИЗАЦИЯ SUPABASE
            const SUPABASE_URL = 'https://hcoaqgwljocbwrlidnfd.supabase.co'; 
            const SUPABASE_ANON_KEY = 'sb_publishable_2pWqV2in9nXcA-Xi-GZMYg_ozrD_ueb';
            const supabase = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
            
            let currentUser = null;

            // ЭЛЕМЕНТЫ АВТОРИЗАЦИИ
            const authOverlay = document.getElementById('authOverlay');
            const emailInput = document.getElementById('authEmail');
            const passInput = document.getElementById('authPassword');
            const nameInput = document.getElementById('authName');
            const errorMsg = document.getElementById('authErrorMsg');
            
            let authMode = 'login';

            const showAuthError = (msg) => {
                errorMsg.innerText = msg;
                errorMsg.classList.remove('hidden');
                setTimeout(() => errorMsg.classList.add('hidden'), 5000);
            };

            // ПЕРЕКЛЮЧЕНИЕ РЕЖИМОВ ВХОД/РЕГИСТРАЦИЯ
            document.getElementById('btnToggleAuth').addEventListener('click', () => {
                authMode = authMode === 'login' ? 'signup' : 'login';
                document.getElementById('nameFieldGroup').style.display = authMode === 'signup' ? 'block' : 'none';
                document.getElementById('authTitle').innerText = authMode === 'signup' ? 'Регистрация' : 'Вход';
                document.getElementById('authSubtitle').innerText = authMode === 'signup' ? 'Создайте аккаунт для облачной синхронизации' : 'Войдите, чтобы синхронизировать прогресс';
                document.getElementById('btnSubmitAuth').innerText = authMode === 'signup' ? 'Зарегистрироваться' : 'Войти';
                document.getElementById('btnToggleAuth').innerText = authMode === 'signup' ? 'Уже есть аккаунт? Войти' : 'Нет аккаунта? Регистрация';
                errorMsg.classList.add('hidden');
            });

            // ОБЩАЯ КНОПКА ОТПРАВКИ ФОРМЫ
            document.getElementById('btnSubmitAuth').addEventListener('click', async () => {
                const email = emailInput.value.trim();
                const password = passInput.value;
                const name = nameInput.value.trim();
                
                if (!email || password.length < 6) return showAuthError("Введите email и пароль (мин. 6 символов)");
                
                document.getElementById('btnSubmitAuth').innerText = "Загрузка...";
                document.getElementById('btnSubmitAuth').disabled = true;

                if (authMode === 'signup') {
                    const { data, error } = await supabase.auth.signUp({ 
                        email, password,
                        options: { data: { full_name: name } }
                    });
                    
                    if (error) {
                        document.getElementById('btnSubmitAuth').innerText = "Зарегистрироваться";
                        document.getElementById('btnSubmitAuth').disabled = false;
                        return showAuthError(error.message);
                    }
                    
                    if (data.user && data.user.identities && data.user.identities.length === 0) {
                        showAuthError("Этот email уже зарегистрирован. Выполните вход.");
                    } else {
                        alert("Успешно! Теперь вы можете войти в систему.");
                        document.getElementById('btnToggleAuth').click(); 
                    }
                    document.getElementById('btnSubmitAuth').innerText = "Зарегистрироваться";
                    document.getElementById('btnSubmitAuth').disabled = false;
                    
                } else {
                    const { data, error } = await supabase.auth.signInWithPassword({ email, password });
                    
                    if (error) {
                        document.getElementById('btnSubmitAuth').innerText = "Войти";
                        document.getElementById('btnSubmitAuth').disabled = false;
                        return showAuthError("Ошибка входа: Неверный логин или пароль");
                    }
                    
                    currentUser = data.user;
                    authOverlay.style.display = 'none';
                    updateUserBadge();
                    await loadFromCloud();
                }
            });

            // ОБНОВЛЕНИЕ ИМЕНИ В ШАПКЕ И ПРОФИЛЕ
            const updateUserBadge = () => {
                if (!currentUser) return;
                const name = currentUser.user_metadata?.full_name || currentUser.email;
                const badge = document.getElementById('userProfileBadge');
                badge.classList.remove('hidden');
                badge.classList.add('flex');
                document.getElementById('userEmailDisplay').innerText = name;
                
                document.getElementById('profileEmail').value = currentUser.email;
                document.getElementById('profileName').value = currentUser.user_metadata?.full_name || '';
            };

            // ЛОГИКА СОХРАНЕНИЯ ПРОФИЛЯ
            document.getElementById('btnSaveProfile').addEventListener('click', async () => {
                const newName = document.getElementById('profileName').value.trim();
                const btn = document.getElementById('btnSaveProfile');
                const originalText = btn.innerHTML;
                btn.innerHTML = `<span class="mr-1.5 sm:mr-2">⏳</span> Сохранение...`;
                
                const { data, error } = await supabase.auth.updateUser({
                    data: { full_name: newName }
                });
                
                if (error) {
                    alert("Ошибка сохранения: " + error.message);
                    btn.innerHTML = originalText;
                } else {
                    currentUser = data.user;
                    updateUserBadge();
                    btn.innerHTML = `<span class="mr-1.5 sm:mr-2">✓</span> Сохранено!`;
                    btn.classList.replace('bg-brand-purple', 'bg-emerald-500');
                    btn.classList.replace('hover:bg-indigo-700', 'hover:bg-emerald-600');
                    setTimeout(() => {
                        btn.innerHTML = originalText;
                        btn.classList.replace('bg-emerald-500', 'bg-brand-purple');
                        btn.classList.replace('hover:bg-emerald-600', 'hover:bg-indigo-700');
                    }, 2000);
                }
            });

            // ЛОГИКА ВЫХОДА ИЗ АККАУНТА
            const handleLogout = async () => {
                await supabase.auth.signOut();
                window.location.reload();
            };
            document.getElementById('btnLogoutHeader').addEventListener('click', handleLogout);
            document.getElementById('btnProfileLogout').addEventListener('click', handleLogout);

            const WEEKS_PER_BLOCK = 13;
            const TOTAL_WEEKS = 52;
            const priorityConfig = {
                high: { color: 'bg-rose-50 text-rose-500 border border-rose-100', label: 'выс' },
                medium: { color: 'bg-amber-50 text-amber-600 border border-amber-100', label: 'ср' },
                low: { color: 'bg-slate-100 text-slate-500 border border-slate-200', label: 'низ' }
            };
            const priorityWeights = { high: 3, medium: 2, low: 1 };

            const defaultRewards = () => ({ 
                gold: {name:'', cost:'', pct:90, image: ''}, 
                silver: {name:'', cost:'', pct:80, image: ''}, 
                bronze: {name:'', cost:'', pct:70, image: ''} 
            });
            
            const defaultData = {
                startDate: '', currentWeek: 1, 
                reflections: {}, 
                goals: [], tasks: [],
                vision: { mission: '', long: '', weeks12: '', 
                    values: [{title:'',desc:''},{title:'',desc:''},{title:'',desc:''}], 
                    anchors: [{title:'',desc:''},{title:'',desc:''},{title:'',desc:''},{title:'',desc:''}], 
                    images: {
                        environment: { label: '1. Моё окружение / пространство', slots: ['', '', '', ''] },
                        places: { label: '2. Места, которые хочу посетить', slots: ['', '', '', ''] },
                        futureSelf: { label: '3. Кем хочу быть / Мотивация', slots: ['', '', '', ''] }
                    }
                },
                rewards: { 1: defaultRewards(), 2: defaultRewards(), 3: defaultRewards(), 4: defaultRewards() }
            };

            const loadData = () => {
                const saved = localStorage.getItem('12WeekAppV27_Yearly'); 
                let data = saved ? JSON.parse(saved) : defaultData;
                
                if (!data.vision.images.environment || !data.vision.images.places || !data.vision.images.futureSelf) {
                    data.vision.images = defaultData.vision.images;
                }
                
                if (!data.rewards) data.rewards = defaultData.rewards;
                if (!data.vision) data.vision = defaultData.vision;
                if (!data.reflections) data.reflections = {};
                data.tasks.forEach(t => { if(!t.priority) t.priority = 'medium'; });
                return data;
            };

            let appData = loadData();
            window.appDataGlobal = appData; 
            
            let saveTimer;
            const saveData = () => { 
                clearTimeout(saveTimer); 
                saveTimer = setTimeout(() => { forceSave(); }, 400); 
            };
            
            const forceSave = async () => { 
                localStorage.setItem('12WeekAppV27_Yearly', JSON.stringify(appData)); 
                
                if (currentUser) {
                    const { error } = await supabase.from('cloud_saves').upsert({ 
                        user_id: currentUser.id, 
                        app_data: appData 
                    });
                    
                    if (error) {
                        console.error("Ошибка синхронизации с облаком:", error.message);
                    } else {
                        console.log("Прогресс сохранен в облако!");
                    }
                }
            };
            window.forceSaveGlobal = forceSave;

            const getBlockFromWeek = (week) => Math.ceil(week / WEEKS_PER_BLOCK);
            const getWeeksForBlock = (block) => { let w = []; for(let i=1; i<=WEEKS_PER_BLOCK; i++) w.push((block-1)*WEEKS_PER_BLOCK + i); return w; };

            const getReflection = (weekNum) => {
                if(!appData.reflections[weekNum]) appData.reflections[weekNum] = { wentWell: '', toImprove: '', rating: 0 };
                return appData.reflections[weekNum];
            };

            const initCurrentWeek = () => {
                if (!appData.startDate) return;
                const start = new Date(appData.startDate); start.setHours(0,0,0,0);
                const now = new Date(); now.setHours(0,0,0,0);
                if (now < start) { appData.currentWeek = 1; } 
                else {
                    const diffDays = Math.floor((now - start) / (1000 * 60 * 60 * 24));
                    const week = Math.floor(diffDays / 7) + 1;
                    appData.currentWeek = week > 52 ? 52 : week;
                }
            };
            initCurrentWeek();
            
            let activeRewardBlock = getBlockFromWeek(appData.currentWeek) || 1; 
            let activePlanBlock = getBlockFromWeek(appData.currentWeek) || 1; 

            document.getElementById('globalSaveBtn').addEventListener('click', (e) => {
                forceSave();
                const btnText = document.getElementById('globalSaveBtnText');
                const btn = e.currentTarget;
                const originalText = btnText.innerText;
                btnText.innerText = "Успех!";
                btn.classList.replace('bg-brand-purple', 'bg-emerald-500'); btn.classList.replace('hover:bg-indigo-700', 'hover:bg-emerald-600');
                setTimeout(() => { 
                    btnText.innerText = originalText;
                    btn.classList.replace('bg-emerald-500', 'bg-brand-purple'); btn.classList.replace('hover:bg-emerald-600', 'hover:bg-indigo-700');
                }, 1500);
            });

            const formatDate = (dateObj) => { return dateObj ? dateObj.toLocaleDateString('ru-RU', { day: 'numeric', month: 'short', year: 'numeric' }) : '--'; };
            const addDays = (ds, d) => { const dt = new Date(ds); dt.setDate(dt.getDate() + d); return dt; };
            const getWeekDates = (w) => { if(!appData.startDate) return { str: '--' }; return { str: `${formatDate(addDays(appData.startDate, (w-1)*7))} - ${formatDate(addDays(appData.startDate, w*7-1))}` }; };
            const getBlockDates = (b) => { if(!appData.startDate) return '--'; return `${formatDate(addDays(appData.startDate, (b-1)*WEEKS_PER_BLOCK*7))} - ${formatDate(addDays(appData.startDate, b*WEEKS_PER_BLOCK*7-1))}`; };

            const getDaysForWeek = (w) => {
                const names = ['Пн', 'Вт', 'Ср', 'Чт', 'Пт', 'Сб', 'Вс'];
                if (!appData.startDate) return names.map(n => ({ name: n, date: '' }));
                const start = addDays(appData.startDate, (w-1)*7);
                return names.map((n, i) => ({ name: n, date: addDays(start, i).toLocaleDateString('ru-RU', { day: '2-digit', month: '2-digit' }) }));
            };

            const updateCalendarUI = () => {
                document.getElementById('todayDateDisplay').innerText = formatDate(new Date());
                const di = document.getElementById('startDateInput');
                if(di) di.value = appData.startDate;
                if (appData.startDate && document.getElementById('displayStartDate')) {
                    document.getElementById('displayStartDate').innerText = formatDate(new Date(appData.startDate));
                    document.getElementById('displayEndDate').innerText = formatDate(addDays(appData.startDate, 363));
                }
            };

            const diEl = document.getElementById('startDateInput');
            if(diEl) {
                diEl.addEventListener('change', (e) => {
                    appData.startDate = e.target.value; initCurrentWeek(); saveData(); 
                    updateCalendarUI(); renderPlanTab(); renderDashboard(); renderReflectionTab(); renderWeekSelector();
                });
            }

            const bindInput = (id, pathFunc) => { const el = document.getElementById(id); if(el) el.addEventListener('input', (e) => { pathFunc(e.target.value); saveData(); }); };
            bindInput('visionMission', v => appData.vision.mission = v); 
            bindInput('visionLong', v => appData.vision.long = v);
            bindInput('vision12Weeks', v => appData.vision.weeks12 = v);
            bindInput('inputWentWell', v => getReflection(appData.currentWeek).wentWell = v);
            bindInput('inputToImprove', v => getReflection(appData.currentWeek).toImprove = v);

            const renderMonthCalendar = (stripId, labelId, weekNum) => {
                const container = document.getElementById(stripId);
                const monthLabel = document.getElementById(labelId);
                if (!appData.startDate) {
                    if(monthLabel) monthLabel.innerText = 'Календарь (не задан старт)';
                    if(container) container.innerHTML = '<p class="text-[10px] sm:text-xs text-slate-400 py-2 sm:py-3 italic px-1 sm:px-2">Укажите дату старта во вкладке Планы и цели, чтобы календарь заработал.</p>';
                    return;
                }
                const actW = weekNum || appData.currentWeek;
                const wStart = addDays(appData.startDate, (actW - 1) * 7);
                const midW = addDays(wStart, 3);
                if(monthLabel) monthLabel.innerText = midW.toLocaleDateString('ru-RU', { month: 'long', year: 'numeric' });
                if(container) {
                    const daysInMonth = new Date(midW.getFullYear(), midW.getMonth() + 1, 0).getDate();
                    const dMap = ['Вс', 'Пн', 'Вт', 'Ср', 'Чт', 'Пт', 'Сб']; 
                    const tZero = new Date().setHours(0,0,0,0);
                    const sZero = new Date(wStart).setHours(0,0,0,0);
                    const eZero = new Date(addDays(wStart, 6)).setHours(0,0,0,0);

                    let h = '';
                    for (let i = 1; i <= daysInMonth; i++) {
                        const cur = new Date(midW.getFullYear(), midW.getMonth(), i);
                        const cZero = cur.setHours(0,0,0,0);
                        const isCurW = cZero >= sZero && cZero <= eZero;
                        const isTod = cZero === tZero;
                        let bg = isCurW ? 'bg-brand-purple text-white shadow-md' : (isTod ? 'bg-white text-brand-purple border-brand-purple/30' : 'bg-slate-50 text-slate-400 border-slate-100');
                        h += `<div class="flex flex-col items-center justify-center flex-1 h-9 sm:h-10 md:h-14 rounded-lg border cursor-default ${bg}">
                            <span class="text-[5px] sm:text-[7px] md:text-[9px] font-bold uppercase opacity-80">${dMap[cur.getDay()]}</span>
                            <span class="text-[8px] sm:text-[10px] md:text-sm font-bold leading-tight ${isTod && !isCurW ? 'text-brand-purple' : ''}">${i}</span>
                            ${isTod ? `<div class="w-0.5 h-0.5 sm:w-1 sm:h-1 rounded-full mt-0.5 ${isCurW ? 'bg-white' : 'bg-brand-purple'}"></div>` : ''}
                        </div>`;
                    }
                    container.innerHTML = h;
                }
            };

            const renderPlanTab = () => {
                document.querySelectorAll('.plan-block-btn').forEach(btn => {
                    btn.className = parseInt(btn.dataset.block) === activePlanBlock 
                        ? "plan-block-btn flex-1 py-1.5 sm:py-2 px-2 sm:px-1 rounded-lg text-[9px] xl:text-xs font-bold bg-white text-brand-purple shadow-sm transition-all whitespace-nowrap min-w-[80px] sm:min-w-0"
                        : "plan-block-btn flex-1 py-1.5 sm:py-2 px-2 sm:px-1 rounded-lg text-[9px] xl:text-xs font-bold text-slate-500 hover:text-slate-800 transition-all bg-transparent whitespace-nowrap min-w-[80px] sm:min-w-0";
                });
                document.getElementById('planCurrentBlockLabel').innerText = `Блок ${activePlanBlock}`;
                document.getElementById('taskSubBlockLabel').innerText = `Блока ${activePlanBlock}`;
                document.getElementById('tasksListHeaderLabel').innerText = `Практики Блока ${activePlanBlock}`;

                const aGoals = appData.goals.filter(g => g.block === activePlanBlock);
                const gList = document.getElementById('goalsList');
                if (aGoals.length === 0) gList.innerHTML = '<p class="text-[10px] sm:text-sm text-slate-400 italic">У вас пока нет целей в этом блоке.</p>';
                else {
                    gList.innerHTML = aGoals.map(g => `
                        <div class="flex justify-between items-start bg-slate-50 p-3 sm:p-4 rounded-xl border border-slate-200 transition-colors w-full">
                            <div class="flex-1 min-w-0 mr-2 sm:mr-4">
                                <div class="flex flex-wrap items-center gap-1 sm:gap-2 mb-1.5 sm:mb-2">
                                    <span class="text-[8px] sm:text-[10px] font-bold bg-brand-purple/10 text-brand-purple px-1.5 sm:px-2 py-0.5 sm:py-1 rounded uppercase tracking-wider whitespace-nowrap">Блок ${g.block}</span>
                                    <span class="text-[8px] sm:text-[10px] text-slate-400 font-medium whitespace-nowrap">${getBlockDates(g.block)}</span>
                                </div>
                                <textarea data-id="${g.id}" class="auto-resize goal-edit-input w-full bg-transparent text-[11px] sm:text-sm font-semibold text-slate-800 leading-snug resize-none overflow-hidden focus:bg-white focus:ring-2 focus:ring-brand-purple/50 rounded-lg p-1.5 sm:p-2 -mx-1.5 sm:-mx-2 transition-all outline-none min-h-[2.5rem] sm:min-h-[3rem] break-words" rows="2" title="Кликните, чтобы отредактировать">${g.title}</textarea>
                            </div>
                            <button data-id="${g.id}" class="delete-goal-btn text-red-400 hover:text-red-600 text-base sm:text-xl leading-none ml-1 shrink-0 self-start mt-1.5 sm:mt-2 p-1.5 sm:p-2" title="Удалить">×</button>
                        </div>`).join('');
                }

                const gSel = document.getElementById('taskGoalSelect');
                if (aGoals.length === 0) gSel.innerHTML = '<option value="">-- Создайте цель в этом блоке --</option>';
                else gSel.innerHTML = '<option value="">-- Выберите цель --</option>' + aGoals.map(g => `<option value="${g.id}">${g.title.substring(0, 50)}...</option>`).join('');
                document.getElementById('addTaskBtn').disabled = aGoals.length === 0;
                
                const evt = new Event('change'); gSel.dispatchEvent(evt);
                
                const tList = document.getElementById('tasksPreviewList');
                const aTasks = appData.tasks.filter(t => aGoals.find(g => g.id === t.goalId));
                if(aTasks.length === 0) tList.innerHTML = '<p class="text-[10px] sm:text-sm text-slate-400 italic">Практики пока не добавлены.</p>';
                else {
                    tList.innerHTML = aTasks.slice().reverse().map(t => {
                        const g = appData.goals.find(x => x.id === t.goalId);
                        const pConf = priorityConfig[t.priority || 'medium'];
                        return `
                        <div class="flex justify-between items-center bg-white p-2 sm:p-3 rounded-lg sm:rounded-xl border border-slate-100 shadow-sm w-full gap-2">
                            <div class="flex-1 min-w-0">
                                <div class="flex flex-wrap items-center text-[8px] sm:text-[10px] text-slate-400 mb-1"><span class="font-bold text-brand-purple mr-1.5 sm:mr-2">Нед. ${t.week}</span> <span class="hidden sm:inline">|</span> <span class="truncate ml-0 sm:ml-2 max-w-full sm:max-w-[150px] w-full sm:w-auto">${g?g.title:'-'}</span></div>
                                <div class="flex flex-wrap items-center gap-1.5 sm:gap-2 mt-0.5 sm:mt-1"><span class="text-xs sm:text-sm shrink-0">${t.type==='daily'?'☀️':'🎯'}</span> <p class="text-[10px] sm:text-sm font-medium text-slate-700 truncate flex-1 min-w-0">${t.title}</p><span class="${pConf.color} px-1.5 sm:px-2 py-0.5 rounded text-[7px] sm:text-[8px] font-bold uppercase shrink-0 mt-1 sm:mt-0">${pConf.label}</span></div>
                            </div>
                            <button data-id="${t.id}" class="delete-task-btn text-red-400 hover:text-red-600 font-bold text-sm sm:text-lg leading-none shrink-0 p-1.5 sm:p-2">×</button>
                        </div>`;
                    }).join('');
                }
            };

            document.getElementById('page-plan').addEventListener('click', e => {
                const blkBtn = e.target.closest('.plan-block-btn');
                if (blkBtn) { activePlanBlock = parseInt(blkBtn.dataset.block); renderPlanTab(); setTimeout(triggerResizeAll, 50); }
                const dGoalBtn = e.target.closest('.delete-goal-btn');
                if(dGoalBtn && confirm("Удалить цель и все её практики?")) {
                    appData.goals = appData.goals.filter(g => g.id !== dGoalBtn.dataset.id);
                    appData.tasks = appData.tasks.filter(t => t.goalId !== dGoalBtn.dataset.id);
                    forceSave(); renderPlanTab(); renderDashboard(); renderReflectionTab(); setTimeout(triggerResizeAll, 50);
                }
                const dTaskBtn = e.target.closest('.delete-task-btn');
                if(dTaskBtn && confirm("Удалить практику?")) {
                    appData.tasks = appData.tasks.filter(t => t.id !== dTaskBtn.dataset.id);
                    forceSave(); renderPlanTab(); renderDashboard(); renderReflectionTab();
                }
            });

            document.getElementById('page-plan').addEventListener('input', e => {
                if(e.target.tagName === 'TEXTAREA' && e.target.dataset.id) {
                    const g = appData.goals.find(x => x.id === e.target.dataset.id);
                    if(g) { g.title = e.target.value.trim(); saveData(); renderDashboard(); renderReflectionTab(); document.getElementById('taskGoalSelect').dispatchEvent(new Event('change')); }
                }
            });

            document.getElementById('taskGoalSelect').addEventListener('change', e => {
                const ws = document.getElementById('newTaskWeek');
                if(!e.target.value) { ws.disabled = true; ws.innerHTML = ''; return; }
                ws.disabled = false;
                const selG = appData.goals.find(g => g.id === e.target.value);
                if(selG) {
                    let h = `<option value="all" class="font-bold text-brand-purple">⚡ Весь блок ${selG.block} (13 нед.)</option>`;
                    getWeeksForBlock(selG.block).forEach(w => {
                        const dStr = getWeekDates(w).str;
                        h += `<option value="${w}" ${w%WEEKS_PER_BLOCK===0 ? 'class="text-amber-600 font-bold"' : ''}>Неделя ${w} ${w%WEEKS_PER_BLOCK===0?'- РЕФЛЕКСИЯ':''} (${dStr})</option>`;
                    });
                    ws.innerHTML = h;
                }
            });

            document.getElementById('addGoalBtn').addEventListener('click', () => {
                const t = document.getElementById('newGoalTitle').value.trim();
                if(t) { appData.goals.push({ id: 'g_'+Date.now(), title: t, block: activePlanBlock }); forceSave(); document.getElementById('newGoalTitle').value = ''; renderPlanTab(); renderDashboard(); setTimeout(triggerResizeAll, 50); }
            });

            document.getElementById('addTaskBtn').addEventListener('click', () => {
                const t = document.getElementById('newTaskTitle').value.trim();
                const gId = document.getElementById('taskGoalSelect').value;
                const type = document.getElementById('newTaskType').value;
                const wVal = document.getElementById('newTaskWeek').value;
                const prio = document.getElementById('newTaskPriority').value;
                if(t && gId && wVal) {
                    const g = appData.goals.find(x => x.id === gId);
                    const wToA = wVal === 'all' ? getWeeksForBlock(g.block) : [parseInt(wVal)];
                    wToA.forEach((w, i) => {
                        appData.tasks.push({ id: 't_'+Date.now()+'_'+i, title: t, goalId: gId, week: w, type: type, priority: prio, done: false, days: type==='daily'?[false,false,false,false,false,false,false]:undefined });
                    });
                    forceSave(); document.getElementById('newTaskTitle').value = ''; renderPlanTab(); renderDashboard();
                }
            });

            const getWeekFactProgress = (wNum) => {
                const wTasks = appData.tasks.filter(t => t.week === wNum);
                let tot = 0, earn = 0;
                wTasks.forEach(t => { if(t.type === 'daily'){ tot+=7; earn+=t.days.filter(d=>d).length; } else { tot+=1; if(t.done) earn+=1; } });
                return { pct: tot===0?0:Math.round((earn/tot)*100), earned: earn, total: tot };
            };
            const getBlockFactProgress = (bNum) => {
                const wks = getWeeksForBlock(bNum);
                const bTasks = appData.tasks.filter(t => wks.includes(t.week));
                let tot = 0, earn = 0;
                bTasks.forEach(t => { if(t.type === 'daily'){ tot+=7; earn+=t.days.filter(d=>d).length; } else { tot+=1; if(t.done) earn+=1; } });
                return { pct: tot===0?0:Math.round((earn/tot)*100), earned: earn, total: tot };
            };

            const renderRewardsTab = () => {
                document.querySelectorAll('.reward-block-btn').forEach(btn => {
                    btn.className = parseInt(btn.dataset.block) === activeRewardBlock 
                        ? "reward-block-btn flex-1 px-2 sm:px-4 py-1.5 sm:py-2 rounded-md sm:rounded-lg text-[9px] sm:text-sm font-bold bg-brand-purple text-white shadow-sm"
                        : "reward-block-btn flex-1 px-2 sm:px-4 py-1.5 sm:py-2 rounded-md sm:rounded-lg text-[9px] sm:text-sm font-bold text-slate-500 hover:bg-slate-200 transition-colors bg-transparent";
                });
                
                const r = appData.rewards[activeRewardBlock];
                const tiers = [
                    { key: 'gold', label: 'Золото', icon: '🥇', colorCls: 'amber-500', focusCls: 'amber-400' },
                    { key: 'silver', label: 'Серебро', icon: '🥈', colorCls: 'slate-500', focusCls: 'slate-400' },
                    { key: 'bronze', label: 'Бронза', icon: '🥉', colorCls: 'orange-600', focusCls: 'orange-400' }
                ];
                
                let html = '';
                tiers.forEach(t => {
                    const data = r[t.key];
                    const hasImg = data.image ? 'has-image' : '';
                    const bgStyle = data.image ? `background-image: url('${data.image}')` : '';
                    
                    html += `
                        <div class="bonus-card border-2 border-slate-200 rounded-2xl sm:rounded-3xl p-4 sm:p-6 md:p-8 relative flex flex-col w-full min-w-0" id="card_${t.key}">
                            <div class="absolute -top-3 -right-3 sm:-top-4 sm:-right-4 text-3xl sm:text-4xl">${t.icon}</div>
                            <h4 class="font-bold text-sm sm:text-lg text-${t.colorCls} uppercase tracking-wider mb-3 sm:mb-6 border-b border-slate-100 pb-2 sm:pb-3">${t.label}</h4>
                            
                            <div class="flex flex-col xl:flex-row gap-3 sm:gap-6 items-start flex-1 w-full min-w-0">
                                <div class="flex-1 space-y-3 sm:space-y-4 w-full min-w-0">
                                    <div><label class="block text-[8px] sm:text-[10px] font-bold text-slate-500 uppercase mb-1">План: Цель (%)</label><input type="number" id="rew${t.key.charAt(0).toUpperCase() + t.key.slice(1)}Pct" class="w-16 sm:w-24 bg-slate-50 rounded-xl p-2 sm:p-3 border border-slate-200 text-xs sm:text-sm font-bold outline-none text-center focus:bg-white focus:ring-2 focus:ring-${t.focusCls}/50 transition-all" min="1" max="100" value="${data.pct}" oninput="appDataGlobal.rewards[${activeRewardBlock}].${t.key}.pct = parseInt(this.value)||0; saveData(); updateRewardsVisuals();"></div>
                                    <div><label class="block text-[8px] sm:text-[10px] font-bold text-slate-500 uppercase mb-1">Что я получу</label><textarea id="rew${t.key.charAt(0).toUpperCase() + t.key.slice(1)}Name" class="auto-resize w-full bg-slate-50 rounded-xl p-2 sm:p-3 border border-slate-200 text-[10px] sm:text-sm outline-none resize-none min-h-[3rem] sm:min-h-[4rem] focus:bg-white focus:ring-2 focus:ring-${t.focusCls}/50 transition-all break-words" oninput="appDataGlobal.rewards[${activeRewardBlock}].${t.key}.name = this.value; saveData();">${data.name}</textarea></div>
                                    <div><label class="block text-[8px] sm:text-[10px] font-bold text-slate-500 uppercase mb-1">Стоимость</label><input type="text" id="rew${t.key.charAt(0).toUpperCase() + t.key.slice(1)}Cost" class="w-full bg-slate-50 rounded-xl p-2 sm:p-3 border border-slate-200 text-[10px] sm:text-sm outline-none focus:bg-white focus:ring-2 focus:ring-${t.focusCls}/50 transition-all break-words" placeholder="Напр. 15 000 руб." value="${data.cost}" oninput="appDataGlobal.rewards[${activeRewardBlock}].${t.key}.cost = this.value; saveData();"></div>
                                </div>
                                <div class="w-full xl:w-48 h-32 sm:h-48 shrink-0">
                                    <div id="rewImg_${t.key}" class="vision-image-card w-full h-full rounded-xl sm:rounded-2xl flex items-center justify-center ${hasImg}" style="${bgStyle}" onclick="if(!event.target.classList.contains('delete-img-btn')) document.getElementById('upRew_${t.key}').click()">
                                        <input type="file" id="upRew_${t.key}" class="hidden" accept="image/*" onchange="window.uploadRewardImage(event, ${activeRewardBlock}, '${t.key}', 'rewImg_${t.key}')">
                                        <div class="vision-upload-icon text-xl sm:text-3xl">📸</div>
                                        <button class="absolute top-1.5 right-1.5 bg-rose-500 hover:bg-rose-600 text-white rounded-full w-5 sm:w-6 h-5 sm:h-6 items-center justify-center delete-img-btn text-[10px] sm:text-xs transition-colors" onclick="window.deleteRewardImage(event, ${activeRewardBlock}, '${t.key}', 'rewImg_${t.key}')">✕</button>
                                        <span class="empty-text text-slate-300 font-medium text-[9px] sm:text-xs mt-6 sm:mt-8 absolute pointer-events-none">Фото награды</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    `;
                });
                
                document.getElementById('rewardsCardsContainer').innerHTML = html;
                updateRewardsVisuals();
                setTimeout(triggerResizeAll, 50);
            };

            const updateRewardsVisuals = () => {
                const f = getBlockFactProgress(activeRewardBlock);
                document.getElementById('rewardFactSubtitle').innerText = `Факт: Блок ${activeRewardBlock}`;
                document.getElementById('rewardFactPct').innerText = `${f.pct}%`;
                document.getElementById('rewardFactScore').innerText = `${f.earned} / ${f.total} очков`;

                const r = appData.rewards[activeRewardBlock];
                let hA = 'none';
                if (f.pct >= r.gold.pct && f.total > 0) hA = 'gold';
                else if (f.pct >= r.silver.pct && f.total > 0) hA = 'silver';
                else if (f.pct >= r.bronze.pct && f.total > 0) hA = 'bronze';

                const bdg = document.getElementById('rewardStatusBadge');
                if (hA === 'gold') { bdg.className = "inline-block w-full md:w-auto text-center px-3 sm:px-4 py-1.5 sm:py-2 rounded-full text-[10px] sm:text-sm font-bold bg-amber-100 text-amber-700 border border-amber-300"; bdg.innerText = "🏆 Золото достигнуто!"; }
                else if (hA === 'silver') { bdg.className = "inline-block w-full md:w-auto text-center px-3 sm:px-4 py-1.5 sm:py-2 rounded-full text-[10px] sm:text-sm font-bold bg-slate-200 text-slate-700 border border-slate-400"; bdg.innerText = "🏆 Серебро достигнуто!"; }
                else if (hA === 'bronze') { bdg.className = "inline-block w-full md:w-auto text-center px-3 sm:px-4 py-1.5 sm:py-2 rounded-full text-[10px] sm:text-sm font-bold bg-orange-100 text-orange-700 border border-orange-300"; bdg.innerText = "🏆 Бронза достигнута!"; }
                else { bdg.className = "inline-block w-full md:w-auto text-center px-3 sm:px-4 py-1.5 sm:py-2 rounded-full text-[10px] sm:text-sm font-bold bg-slate-800 text-slate-400 border border-slate-700 truncate"; bdg.innerText = "Пока не достигнуто"; }

                ['gold', 'silver', 'bronze'].forEach(t => {
                    const c = document.getElementById('card_' + t);
                    if(!c) return;
                    c.classList.remove('achieved', 'bonus-locked');
                    if (hA === t || (hA==='gold') || (hA==='silver' && t==='bronze')) c.classList.add('achieved');
                    else c.classList.add('bonus-locked');
                });
            };

            document.querySelectorAll('.reward-block-btn').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    activeRewardBlock = parseInt(e.target.dataset.block);
                    renderRewardsTab();
                });
            });

            const renderDashboard = () => {
                const curB = getBlockFromWeek(appData.currentWeek);
                document.getElementById('currentBlockLabel').innerText = `БЛОК ${curB}`;
                document.getElementById('dashBlockTitle').innerText = `Фокус Блока ${curB}`;
                document.getElementById('dashBlockDates').innerText = getBlockDates(curB);
                document.getElementById('dashWeekTitle').innerText = `Неделя ${appData.currentWeek}`;
                document.getElementById('dashWeekDates').innerText = getWeekDates(appData.currentWeek).str;
                
                document.getElementById('dashMissionText').innerText = appData.vision.mission || "Сформулируйте свою миссию во вкладке «Личное видение».";
                document.getElementById('dashVisionText').innerText = appData.vision.weeks12 || "Сформулируйте видение на 12 недель во вкладке «Личное видение».";

                renderMonthCalendar('monthCalendarStrip', 'calendarMonthName', appData.currentWeek);

                const gc = document.getElementById('dashboardGoalsContainer');
                const cbGoals = appData.goals.filter(g => g.block === curB);
                let totW = 0, earnW = 0;
                const cWDays = getDaysForWeek(appData.currentWeek);

                if (cbGoals.length === 0) {
                    gc.innerHTML = `<div class="bg-indigo-50/50 rounded-2xl sm:rounded-3xl p-5 sm:p-10 text-center border border-indigo-100 border-dashed w-full"><span class="text-2xl sm:text-4xl block mb-2 sm:mb-3">🎯</span><h3 class="text-xs sm:text-lg font-bold text-indigo-900 mb-1 sm:mb-2">Целей на этот квартал пока нет</h3></div>`;
                } else {
                    let h = '';
                    cbGoals.forEach((g) => {
                        let gTasks = appData.tasks.filter(t => t.goalId === g.id && t.week === appData.currentWeek);
                        let dTasks = gTasks.filter(t => t.type === 'daily');
                        let wTasks = gTasks.filter(t => t.type === 'weekly');
                        
                        const srt = (a, b) => priorityWeights[b.priority || 'medium'] - priorityWeights[a.priority || 'medium'];
                        dTasks.sort(srt); wTasks.sort(srt);

                        let dT = dTasks.length * 7, dE = dTasks.reduce((s, t) => s + t.days.filter(x=>x).length, 0), dP = dT===0?0:Math.round((dE/dT)*100);
                        let wT = wTasks.length, wE = wTasks.reduce((s, t) => s + (t.done?1:0), 0), wP = wT===0?0:Math.round((wE/wT)*100);
                        
                        totW += dT + wT; earnW += dE + wE;

                        let dtHtml = dTasks.length === 0 ? '<p class="text-[10px] sm:text-xs text-slate-300 italic">Нет ежедневных практик на эту неделю.</p>' : dTasks.map(t => {
                            const pC = priorityConfig[t.priority || 'medium'];
                            const dPct = Math.round((t.days.filter(x=>x).length / 7) * 100);
                            return `
                            <div class="bg-slate-50/50 rounded-xl sm:rounded-2xl p-3 sm:p-5 border border-slate-100 mb-3 sm:mb-4 w-full">
                                <div class="flex flex-col sm:flex-row sm:items-center justify-between mb-2.5 sm:mb-4 gap-2 sm:gap-4 w-full min-w-0">
                                    <p class="font-bold text-slate-800 text-[10px] sm:text-sm truncate flex-1 min-w-0 w-full" title="${t.title}">${t.title}</p>
                                    <div class="flex items-center gap-1.5 sm:gap-3 shrink-0">
                                        <div class="flex items-center gap-2 hidden md:flex"><div class="h-1.5 w-16 bg-slate-200 rounded-full overflow-hidden"><div class="h-full bg-emerald-400" style="width: ${dPct}%"></div></div></div>
                                        <span class="${pC.color} px-1.5 sm:px-2.5 py-0.5 sm:py-1 rounded-md text-[7px] sm:text-[10px] font-bold uppercase tracking-wide">${pC.label}</span>
                                    </div>
                                </div>
                                <div class="flex justify-between gap-0.5 sm:gap-2 w-full">
                                    ${t.days.map((isD, i) => {
                                        const dInf = cWDays[i];
                                        const c = isD ? "bg-brand-purple text-white border-brand-purple shadow-sm font-bold scale-105" : "bg-white text-slate-500 border-slate-200 hover:border-brand-purple/50 hover:text-brand-purple font-medium";
                                        return `<button data-tid="${t.id}" data-did="${i}" class="dash-day-btn flex flex-col items-center justify-center flex-1 rounded-lg sm:rounded-xl text-[8px] sm:text-xs transition-all py-1 sm:py-2 border ${c} outline-none min-w-0"><span class="mb-0 sm:mb-0.5">${dInf.name}</span>${dInf.date ? `<span class="text-[6px] sm:text-[9px] opacity-70 font-normal hidden sm:block">${dInf.date.substring(0,5)}</span>` : ''}</button>`;
                                    }).join('')}
                                </div>
                            </div>`;
                        }).join('');

                        let wtHtml = wTasks.length === 0 ? '<p class="text-[10px] sm:text-xs text-slate-300 italic">Нет еженедельных тактик на эту неделю.</p>' : wTasks.map(t => {
                            const pC = priorityConfig[t.priority || 'medium'];
                            return `
                            <button data-tid="${t.id}" class="dash-week-btn w-full bg-${t.done?'slate-50':'white'} rounded-xl p-2.5 sm:p-4 flex flex-nowrap items-center justify-between border border-slate-200 hover:border-brand-purple/50 transition-all mb-2 sm:mb-3 group outline-none text-left gap-2 min-w-0">
                                <div class="flex items-center min-w-0 flex-1 pr-1 sm:pr-4">
                                    <div class="w-3.5 h-3.5 sm:w-5 sm:h-5 rounded-full ${t.done?'bg-slate-200 text-slate-500 border-none':'border-2 border-slate-300 group-hover:border-brand-purple/50'} flex shrink-0 items-center justify-center text-[7px] sm:text-[10px] mr-1.5 sm:mr-3 transition-colors">${t.done?'✓':''}</div>
                                    <p class="font-medium ${t.done?'text-slate-400 line-through':'text-slate-700'} text-[10px] sm:text-sm break-words line-clamp-2 w-full">${t.title}</p>
                                </div>
                                <span class="${pC.color} ${t.done?'opacity-50':''} px-1.5 sm:px-2.5 py-0.5 sm:py-1 rounded-md text-[7px] sm:text-[10px] font-bold uppercase shrink-0">${pC.label}</span>
                            </button>`;
                        }).join('');

                        h += `
                        <div class="bg-white rounded-2xl sm:rounded-3xl p-4 sm:p-6 md:p-8 shadow-[0_2px_10px_rgba(0,0,0,0.02)] border border-slate-100 mb-5 sm:mb-6 w-full min-w-0">
                            <h3 class="text-base sm:text-2xl font-bold text-slate-800 mb-4 sm:mb-8 break-words w-full">${g.title}</h3>
                            <div class="grid grid-cols-1 xl:grid-cols-2 gap-5 sm:gap-8 w-full min-w-0">
                                <div class="w-full min-w-0">
                                    <div class="flex items-center justify-between mb-3 sm:mb-4 gap-2 sm:gap-4 w-full">
                                        <h4 class="text-[8px] sm:text-[10px] font-bold text-slate-400 uppercase tracking-widest flex items-center shrink-0"><span class="mr-1 sm:mr-2 text-brand-purple text-sm sm:text-lg">☀️</span> ЕЖЕДНЕВНЫЕ ПРАКТИКИ</h4>
                                        ${dT>0 ? `<div class="flex items-center justify-end gap-1.5 sm:gap-2 flex-1 min-w-0"><div class="h-1 sm:h-1.5 w-full bg-slate-100 rounded-full overflow-hidden max-w-[60px] sm:max-w-[120px]"><div class="h-full bg-brand-purple transition-all" style="width: ${dP}%"></div></div><span class="text-[8px] sm:text-[10px] font-bold text-brand-purple w-5 sm:w-8 text-right">${dP}%</span></div>` : ''}
                                    </div>
                                    <div class="space-y-2 sm:space-y-4 w-full">${dtHtml}</div>
                                </div>
                                <div class="w-full min-w-0">
                                    <div class="flex items-center justify-between mb-3 sm:mb-4 gap-2 sm:gap-4 w-full">
                                        <h4 class="text-[8px] sm:text-[10px] font-bold text-slate-400 uppercase tracking-widest flex items-center shrink-0"><span class="mr-1 sm:mr-2 text-rose-400 text-sm sm:text-lg">🎯</span> ЕЖЕНЕДЕЛЬНЫЕ ТАКТИКИ</h4>
                                        ${wT>0 ? `<div class="flex items-center justify-end gap-1.5 sm:gap-2 flex-1 min-w-0"><div class="h-1 sm:h-1.5 w-full bg-slate-100 rounded-full overflow-hidden max-w-[60px] sm:max-w-[120px]"><div class="h-full bg-rose-400 transition-all" style="width: ${wP}%"></div></div><span class="text-[8px] sm:text-[10px] font-bold text-rose-500 w-5 sm:w-8 text-right">${wP}%</span></div>` : ''}
                                    </div>
                                    <div class="space-y-2 sm:space-y-3 w-full">${wtHtml}</div>
                                </div>
                            </div>
                        </div>`;
                    });
                    gc.innerHTML = h;
                }

                const pct = totW === 0 ? 0 : Math.round((earnW / totW) * 100);
                document.getElementById('cycleSpeed').innerText = pct + '%';
                document.getElementById('cycleProgressBar').style.width = pct + '%';
                document.getElementById('scoreDetails').innerText = `${earnW} / ${totW} очков выполнено`;

                const bCont = document.getElementById('dashboardBlocksContainer');
                let bh = `<div class="mb-3 sm:mb-6 border-b border-slate-100 pb-2 sm:pb-4"><h3 class="text-base sm:text-xl font-bold text-slate-800">Прогресс года по кварталам</h3><p class="text-[9px] sm:text-xs text-slate-500 mt-1">Сводная статистика исполнения по всем 52 неделям</p></div><div class="grid grid-cols-1 md:grid-cols-2 gap-3 sm:gap-6 w-full">`;
                for (let b = 1; b <= 4; b++) {
                    const bs = getBlockFactProgress(b);
                    const weeks = getWeeksForBlock(b);
                    let wHtml = '<div class="flex flex-wrap gap-0.5 sm:gap-1.5 mt-2 sm:mt-3">';
                    
                    weeks.forEach(w => {
                        const wStats = getWeekFactProgress(w);
                        const isCurrent = w === appData.currentWeek, iR = w % WEEKS_PER_BLOCK === 0;
                        let c = 'bg-slate-100 text-slate-400';
                        if(iR) c = 'bg-amber-100 text-amber-700 border border-amber-200';
                        else if(wStats.total > 0) { if(wStats.pct >= 85) c = 'bg-emerald-500 text-white border border-emerald-600'; else if(wStats.pct >= 50) c = 'bg-emerald-300 text-emerald-900 border border-emerald-400'; else c = 'bg-rose-200 text-rose-900 border border-rose-300'; }
                        wHtml += `<div class="w-4 h-4 sm:w-7 sm:h-7 rounded flex items-center justify-center text-[7px] sm:text-[9px] font-bold ${c} ${isCurrent?'ring-1 sm:ring-2 ring-brand-purple ring-offset-1 scale-110 z-10':''} cursor-default" title="${iR?'Рефлексия':wStats.pct+'%'}">${w}</div>`;
                    });
                    wHtml += '</div>';
                    bh += `<div class="bg-slate-50 rounded-xl sm:rounded-2xl p-3 sm:p-5 border border-slate-100 w-full"><div class="flex justify-between items-center mb-2 sm:mb-4"><div><h4 class="font-bold text-[11px] sm:text-base text-slate-800">Блок ${b} <span class="hidden sm:inline">(Квартал)</span></h4><span class="text-[8px] sm:text-[10px] text-slate-400 block sm:inline">${getBlockDates(b)}</span></div><div class="text-right"><span class="text-sm sm:text-lg font-bold text-brand-purple">${bs.pct}%</span><div class="text-[8px] sm:text-[10px] text-slate-500">${bs.earned}/${bs.total} очков</div></div></div><div class="pt-1.5 sm:pt-2 border-t border-slate-200/60">${wHtml}</div></div>`;
                }
                bCont.innerHTML = bh + '</div>';
            };

            document.getElementById('dashboardGoalsContainer').addEventListener('click', e => {
                const dbBtn = e.target.closest('.dash-day-btn');
                if (dbBtn) {
                    const t = appData.tasks.find(x => x.id === dbBtn.dataset.tid);
                    if(t) { t.days[dbBtn.dataset.did] = !t.days[dbBtn.dataset.did]; forceSave(); renderDashboard(); renderReflectionTab(); }
                }
                const dwBtn = e.target.closest('.dash-week-btn');
                if (dwBtn) {
                    const t = appData.tasks.find(x => x.id === dwBtn.dataset.tid);
                    if(t) { t.done = !t.done; forceSave(); renderDashboard(); renderReflectionTab(); }
                }
            });

            const renderWeekSelector = () => {
                const c = document.getElementById('weekSelector');
                let h = '';
                for(let i = 1; i <= TOTAL_WEEKS; i++) {
                    const iR = i % WEEKS_PER_BLOCK === 0, iC = i === appData.currentWeek;
                    let bClass = "h-5 sm:h-6 flex items-center justify-center rounded cursor-pointer text-[8px] sm:text-[10px] font-semibold transition-all ";
                    if (iC) bClass += "bg-brand-purple text-white shadow-md scale-110 z-10 font-bold ";
                    else if (iR) bClass += "bg-amber-100 text-amber-700 border border-amber-200 hover:bg-amber-200 ";
                    else bClass += "bg-white border border-slate-200 text-slate-500 hover:border-brand-purple hover:text-brand-purple ";
                    h += `<span data-wk="${i}" class="week-sel-btn ${bClass}" title="Неделя ${i}${iR?' (Рефлексия)':''}">${i}</span>`;
                }
                c.innerHTML = h;
            };

            document.getElementById('weekSelector').addEventListener('click', e => {
                const btn = e.target.closest('.week-sel-btn');
                if(btn) {
                    appData.currentWeek = parseInt(btn.dataset.wk); forceSave(); renderWeekSelector(); 
                    const act = document.querySelector('.page-view.active').id;
                    if(act === 'page-dashboard') renderDashboard();
                    if(act === 'page-reflection') renderReflectionTab();
                }
            });
            
            const renderReflectionTab = () => {
                const cBN = getBlockFromWeek(appData.currentWeek);
                document.getElementById('reflectBlockLabel').innerText = `Блок ${cBN}`;
                document.getElementById('reflectWeekDates').innerText = getWeekDates(appData.currentWeek).str;
                document.getElementById('reflectWeekTitle').innerText = `Рефлексия недели ${appData.currentWeek}`;
                
                const ref = getReflection(appData.currentWeek);
                const iw = document.getElementById('inputWentWell');
                const it = document.getElementById('inputToImprove');
                iw.value = ref.wentWell || '';
                it.value = ref.toImprove || '';
                setTimeout(() => { autoResizeTextarea(iw); autoResizeTextarea(it); }, 10);

                document.getElementById('reflectWeekScorePrc').innerText = `${getWeekFactProgress(appData.currentWeek).pct}%`;
                document.getElementById('reflectWeekScoreBar').style.width = `${getWeekFactProgress(appData.currentWeek).pct}%`;

                const rC = document.getElementById('ratingContainer');
                let rh = '';
                for(let i=1; i<=5; i++) {
                    const sel = i === ref.rating;
                    rh += `<button data-val="${i}" class="reflection-rating-btn group flex flex-col items-center gap-1 sm:gap-2 flex-1 outline-none">
                        <span class="${sel?'text-[10px] sm:text-sm font-bold text-slate-800':'text-[8px] sm:text-xs font-bold text-slate-400 group-hover:text-slate-700'} transition-colors">${i}</span>
                        <div class="w-full h-6 sm:h-10 rounded-full border-2 ${sel?'border-brand-purple bg-brand-purple shadow-md scale-110 text-white font-bold':'border-slate-300 bg-white group-hover:border-slate-400 text-slate-500 font-normal'} transition-colors flex items-center justify-center text-sm sm:text-xl">${sel?'✓':'◯'}</div>
                    </button>`;
                }
                rC.innerHTML = rh;

                const bDynList = document.getElementById('reflectionBlockDynamicsList');
                const bWeeks = getWeeksForBlock(cBN);
                let dHtml = '';
                bWeeks.forEach(w => {
                    const wSt = getWeekFactProgress(w);
                    const wRef = getReflection(w);
                    let stars = '';
                    for(let s=1; s<=5; s++) stars += `<span class="${s<=wRef.rating?'text-amber-400':'text-slate-200'} text-[10px] sm:text-sm">★</span>`;
                    
                    const isCur = w === appData.currentWeek;
                    dHtml += `
                    <div class="flex items-center justify-between text-[8px] sm:text-xs p-1.5 sm:p-2.5 rounded-lg sm:rounded-xl border ${isCur?'bg-indigo-50/50 border-brand-purple/30':'bg-slate-50/50 border-slate-100'} mb-1 sm:mb-0">
                        <span class="font-bold ${isCur?'text-brand-purple':'text-slate-600'} w-8 sm:w-14 truncate">Нед. ${w}</span>
                        <div class="flex items-center gap-1 sm:gap-2 flex-1 mx-1.5 sm:mx-2 hidden sm:flex min-w-0">
                           <div class="flex-1 h-1 sm:h-1.5 bg-slate-200 rounded-full overflow-hidden">
                               <div class="h-full ${isCur?'bg-brand-purple':'bg-emerald-400'}" style="width: ${wSt.pct}%"></div>
                           </div>
                           <span class="text-[7px] sm:text-[10px] font-bold ${isCur?'text-brand-purple':'text-slate-500'} w-5 sm:w-8 text-right">${wSt.pct}%</span>
                        </div>
                        <div class="flex gap-0.5 w-max shrink-0">${stars}</div>
                    </div>`;
                });
                bDynList.innerHTML = dHtml;

                const tC = document.getElementById('reflectionWeekTaskList');
                const wT = appData.tasks.filter(t => t.week === appData.currentWeek);
                if(wT.length === 0) tC.innerHTML = '<p class="text-[10px] sm:text-sm text-slate-400 italic p-3 sm:p-4 text-center">Задач на эту неделю запланировано не было.</p>';
                else {
                    tC.innerHTML = wT.map(t => {
                        const g = appData.goals.find(x => x.id === t.goalId);
                        let sH = '', bg = 'bg-white border-slate-200', tx = 'text-slate-700';
                        if(t.type === 'daily') {
                            const dD = t.days.filter(d=>d).length;
                            sH = `<span class="text-[8px] sm:text-xs font-bold text-brand-purple px-1.5 sm:px-2 py-0.5 sm:py-1 rounded bg-brand-purple/5 border border-brand-purple/10 whitespace-nowrap">${dD} / 7 дн.</span>`;
                            if(dD === 7) bg = 'bg-emerald-50 border-emerald-200';
                        } else {
                            if(t.done) { sH = `<span class="text-[8px] sm:text-xs font-bold text-emerald-600 px-1.5 sm:px-2 py-0.5 sm:py-1 rounded bg-emerald-100 border border-emerald-200 whitespace-nowrap">Выполнено</span>`; bg = 'bg-emerald-50 border-emerald-200'; tx = 'text-emerald-800 line-through opacity-70'; } 
                            else sH = `<span class="text-[8px] sm:text-xs font-bold text-slate-500 px-1.5 sm:px-2 py-0.5 sm:py-1 rounded bg-slate-100 border border-slate-200 whitespace-nowrap">Не выполнено</span>`;
                        }
                        return `<div class="flex flex-col sm:flex-row sm:items-center justify-between p-2.5 sm:p-4 rounded-xl sm:rounded-2xl border ${bg} gap-2 sm:gap-4 shadow-sm w-full">
                            <div class="flex items-center gap-2 sm:gap-3 min-w-0 w-full sm:w-auto">
                                <span class="text-sm sm:text-lg shrink-0">${t.type==='daily'?'☀️':'🎯'}</span>
                                <div class="min-w-0 flex-1">
                                    <p class="text-[8px] sm:text-xs text-slate-400 truncate">${g?g.title:'-'}</p>
                                    <p class="text-[10px] sm:text-sm font-medium ${tx} break-words line-clamp-2">${t.title}</p>
                                </div>
                            </div>
                            <div class="shrink-0 self-start sm:self-auto">${sH}</div>
                        </div>`;
                    }).join('');
                }
            };

            document.getElementById('ratingContainer').addEventListener('click', e => {
                const b = e.target.closest('.reflection-rating-btn');
                if(b) { getReflection(appData.currentWeek).rating = parseInt(b.dataset.val); forceSave(); renderReflectionTab(); }
            });

            const renderVisionTab = () => {
                document.getElementById('visionMission').value = appData.vision.mission || '';
                document.getElementById('visionLong').value = appData.vision.long || '';
                document.getElementById('vision12Weeks').value = appData.vision.weeks12 || '';

                const photoContainer = document.getElementById('visionPhotoGroupsContainer');
                let photoHtml = '';
                const groups = [
                    { key: 'environment', label: appData.vision.images.environment.label },
                    { key: 'places', label: appData.vision.images.places.label },
                    { key: 'futureSelf', label: appData.vision.images.futureSelf.label }
                ];

                groups.forEach(group => {
                    const groupData = appData.vision.images[group.key];
                    photoHtml += `
                        <div class="bg-white p-4 sm:p-6 rounded-2xl sm:rounded-3xl shadow-[0_2px_10px_rgba(0,0,0,0.02)] border border-slate-100 w-full min-w-0">
                            <input type="text" class="w-full bg-transparent font-bold text-slate-500 text-[10px] sm:text-sm uppercase tracking-wider mb-3 sm:mb-5 border-b border-slate-100 pb-2 sm:pb-3 outline-none focus:text-brand-purple transition-colors truncate" value="${groupData.label}" oninput="appDataGlobal.vision.images['${group.key}'].label=this.value; saveData()">
                            <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 sm:gap-4 w-full">
                                ${groupData.slots.map((imgBase64, idx) => {
                                    const slotId = `vis_${group.key}_${idx}`;
                                    const inputId = `up_${group.key}_${idx}`;
                                    const hasImg = imgBase64 ? 'has-image' : '';
                                    const bgStyle = imgBase64 ? `background-image: url('${imgBase64}')` : '';
                                    return `
                                        <div id="${slotId}" class="vision-image-card aspect-square ${hasImg}" style="${bgStyle}" onclick="if(!event.target.closest('.delete-img-btn')) document.getElementById('${inputId}').click()">
                                            <input type="file" id="${inputId}" class="hidden" accept="image/*" onchange="window.uploadVisionImage(event, '${group.key}', ${idx}, '${slotId}')">
                                            <div class="vision-upload-icon text-lg sm:text-2xl">📸</div>
                                            <button class="absolute top-1 sm:top-1.5 right-1 sm:right-1.5 bg-rose-500 hover:bg-rose-600 text-white rounded-full w-4 h-4 sm:w-5 sm:h-5 items-center justify-center delete-img-btn text-[8px] sm:text-xs transition-colors" onclick="window.deleteVisionImage(event, '${group.key}', ${idx}, '${slotId}')">✕</button>
                                        </div>
                                    `;
                                }).join('')}
                            </div>
                        </div>
                    `;
                });
                photoContainer.innerHTML = photoHtml;

                const aColors = ['indigo', 'sky', 'amber', 'rose'];
                document.getElementById('visionValuesContainer').innerHTML = appData.vision.values.map((v, i) => `
                    <div class="bg-${i===1?'emerald':'slate'}-50/50 p-2.5 sm:p-4 rounded-xl sm:rounded-2xl border border-${i===1?'emerald':'slate'}-100 w-full">
                        <input type="text" class="vision-input w-full bg-transparent font-bold text-${i===1?'emerald':'slate'}-800 text-[10px] sm:text-sm mb-1 focus:bg-white focus:ring-2 focus:ring-${i===1?'emerald':'slate'}-400/50 rounded-lg p-1.5 sm:p-2 -mx-1.5 sm:-mx-2 outline-none transition-all truncate" placeholder="Ценность ${i+1}" value="${v.title}" oninput="appDataGlobal.vision.values[${i}].title=this.value; saveData()">
                        <textarea class="auto-resize vision-input w-full bg-transparent text-[9px] sm:text-sm text-${i===1?'emerald-700':'slate-600'} resize-none min-h-[2.5rem] sm:min-h-[3rem] focus:bg-white focus:ring-2 focus:ring-${i===1?'emerald':'slate'}-400/50 rounded-lg p-1.5 sm:p-2 -mx-1.5 sm:-mx-2 outline-none transition-all mt-0.5 sm:mt-1 break-words" placeholder="Описание..." oninput="appDataGlobal.vision.values[${i}].desc=this.value; saveData()">${v.desc}</textarea>
                    </div>`).join('');
                    
                document.getElementById('visionAnchorsContainer').innerHTML = appData.vision.anchors.map((a, i) => `
                    <div class="bg-${aColors[i]}-50/50 p-3 sm:p-5 rounded-xl sm:rounded-2xl border border-${aColors[i]}-100/50 flex flex-col h-full min-h-[6rem] sm:min-h-[10rem] w-full">
                        <input type="text" class="vision-input w-full bg-transparent font-bold text-${aColors[i]}-900 text-[8px] sm:text-xs uppercase tracking-wider mb-1 sm:mb-2 focus:bg-white focus:ring-2 focus:ring-${aColors[i]}-400/50 rounded-lg p-1.5 sm:p-2 -mx-1.5 sm:-mx-2 outline-none transition-all truncate" placeholder="ЯКОРЬ" value="${a.title}" oninput="appDataGlobal.vision.anchors[${i}].title=this.value; saveData()">
                        <textarea class="auto-resize vision-input w-full flex-1 bg-transparent text-[10px] sm:text-sm text-${aColors[i]}-800 resize-none min-h-[2.5rem] sm:min-h-[4rem] focus:bg-white focus:ring-2 focus:ring-${aColors[i]}-400/50 rounded-lg p-1.5 sm:p-2 -mx-1.5 sm:-mx-2 outline-none transition-all mt-0.5 sm:mt-1 break-words" placeholder="Описание..." oninput="appDataGlobal.vision.anchors[${i}].desc=this.value; saveData()">${a.desc}</textarea>
                    </div>`).join('');

                const bs = getBlockFactProgress(getBlockFromWeek(appData.currentWeek));
                document.getElementById('visionBlockProgress').style.width = bs.pct + '%';
                document.getElementById('visionBlockProgressText').innerText = `Прогресс: ${bs.pct}%`;
                
                setTimeout(triggerResizeAll, 50);
            };

            const switchPage = (targetId) => {
                document.querySelectorAll('.page-view').forEach(p => p.classList.remove('active'));
                const tp = document.getElementById(`page-${targetId}`);
                if(tp) tp.classList.add('active');
                
                document.querySelectorAll('.nav-btn').forEach(btn => {
                    btn.className = btn.dataset.target === targetId 
                        ? "nav-btn w-full flex items-center px-4 py-3 bg-white text-brand-purple rounded-xl shadow-sm text-sm font-bold transition-colors"
                        : "nav-btn w-full flex items-center px-4 py-3 text-slate-500 hover:bg-slate-100 rounded-xl text-sm font-medium transition-colors";
                });
                
                const hw = document.getElementById('headerWeekSelectorBlock');
                if(targetId === 'dashboard' || targetId === 'reflection') {
                    hw.style.display = 'flex';
                    if(targetId === 'dashboard') renderDashboard();
                    if(targetId === 'reflection') renderReflectionTab();
                } else {
                    hw.style.display = 'none'; 
                    if(targetId === 'plan') renderPlanTab();
                    if(targetId === 'rewards') renderRewardsTab();
                    if(targetId === 'vision') renderVisionTab();
                }
                
                document.getElementById('mainScrollArea').scrollTo(0,0);
                
                if (window.innerWidth < 1024 && !sidebar.classList.contains('-translate-x-full')) {
                    toggleSidebar();
                }
            };

            document.querySelectorAll('.nav-btn').forEach(btn => btn.addEventListener('click', () => switchPage(btn.dataset.target)));

            // ФУНКЦИЯ ЗАГРУЗКИ ИЗ ОБЛАКА
            async function loadFromCloud() {
                if (!currentUser) return;
                try {
                    const { data, error } = await supabase
                        .from('cloud_saves')
                        .select('app_data')
                        .eq('user_id', currentUser.id)
                        .single();
                        
                    if (data && data.app_data) {
                        appData = data.app_data;
                        window.appDataGlobal = appData;
                        
                        initCurrentWeek();
                        updateCalendarUI(); 
                        renderWeekSelector();
                        
                        const activeTab = document.querySelector('.page-view.active').id.replace('page-', '');
                        switchPage(activeTab);
                        
                        console.log("Данные успешно загружены из облака!");
                    }
                } catch (err) {
                    console.error("Ошибка при загрузке:", err);
                }
            }

            // ПРОВЕРКА СЕССИИ ПРИ ЗАГРУЗКЕ СТРАНИЦЫ
            supabase.auth.getSession().then(({ data: { session } }) => {
                if (session) {
                    currentUser = session.user;
                    authOverlay.style.display = 'none';
                    console.log("Сессия восстановлена. ID:", currentUser.id);
                    
                    updateUserBadge();

                    loadFromCloud(); 
                }
            });

            updateCalendarUI(); renderWeekSelector(); switchPage('dashboard');
        });
    </script>
</body>
</html>
}

