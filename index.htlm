                        <p class="text-slate-500 text-[10px] sm:text-sm mb-4 sm:mb-8 relative z-10">Настройки аккаунта.</p>
                        
                        <div class="space-y-4 sm:space-y-6 relative z-10 w-full">
                            <div class="w-full">
                                <label class="block text-[9px] sm:text-xs font-bold text-slate-600 uppercase mb-1.5 sm:mb-2 ml-1">Email аккаунта</label>
                                <input type="text" id="profileEmail" class="w-full bg-slate-50 rounded-xl p-3 sm:p-4 border border-slate-200 text-xs sm:text-sm font-medium text-slate-500 cursor-not-allowed truncate" disabled value="--">
