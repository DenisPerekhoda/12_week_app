            <div id="page-profile" class="page-view w-full">
                <div class="max-w-2xl mx-auto w-full min-w-0">
                    <div class="bg-white rounded-2xl sm:rounded-3xl p-5 sm:p-8 md:p-10 shadow-[0_2px_15px_rgba(0,0,0,0.03)] border border-slate-100 mb-5 sm:mb-8 relative overflow-hidden w-full">
                        <div class="absolute top-0 right-0 p-3 sm:p-6 text-3xl sm:text-4xl opacity-10">👤</div>
