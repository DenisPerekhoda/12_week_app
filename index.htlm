                            <div class="bg-white rounded-2xl sm:rounded-3xl p-5 sm:p-8 shadow-[0_2px_10px_rgba(0,0,0,0.02)] border border-slate-100 flex flex-col h-max w-full">
                                <h3 class="text-sm sm:text-lg font-bold text-slate-800 mb-3 sm:mb-5 flex items-center"><span class="text-brand-purple mr-1.5 sm:mr-2 text-lg sm:text-xl">✔</span> Основные ценности</h3>
                                <div class="space-y-3 sm:space-y-4 flex-1 w-full" id="visionValuesContainer"></div>
