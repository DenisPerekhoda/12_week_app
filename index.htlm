                        <div class="relative z-10 w-full min-w-0">
                            <h3 class="text-base sm:text-xl font-bold text-slate-800 mb-3 sm:mb-6 flex items-center gap-1.5 sm:gap-3 truncate"><span class="text-lg sm:text-2xl">✓</span> Задачи этой недели</h3>
                            <div id="reflectionWeekTaskList" class="space-y-2 sm:space-y-3 w-full"></div>
