            <div id="page-vision" class="page-view w-full">
                <div class="max-w-[1400px] mx-auto pb-6 sm:pb-10 space-y-5 sm:space-y-8 w-full min-w-0">
                    <div class="mb-4 w-full min-w-0">
                        <h2 class="text-xl sm:text-3xl font-bold text-slate-800 mb-1.5 sm:mb-2">Личное видение</h2>
                        <p class="text-[10px] sm:text-sm text-slate-500 mb-4 sm:mb-6">Заполните миссию и добавьте вдохновляющие фото в группы.</p>
                        
                        <div class="bg-gradient-to-r from-indigo-50 to-purple-50/50 rounded-2xl sm:rounded-3xl p-4 sm:p-8 border border-indigo-100/50 text-center relative overflow-hidden h-max shadow-sm w-full">
                           <div class="absolute top-0 right-0 p-3 sm:p-6 text-2xl sm:text-4xl opacity-10">✨</div>
                           <label class="block text-[9px] sm:text-xs font-bold text-rose-600 uppercase tracking-widest mb-2 sm:mb-4">Главная Миссия (Кредо)</label>
                           <textarea id="visionMission" class="auto-resize vision-input w-full bg-transparent p-0 text-slate-800 resize-none font-semibold text-base sm:text-xl leading-relaxed text-center placeholder:text-slate-300 min-h-[3rem] sm:min-h-[4rem] outline-none focus:ring-0 break-words" placeholder="«Прервать цепь боли...»"></textarea>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 lg:grid-cols-12 gap-5 sm:gap-8 items-start w-full">
                        
                        <div class="lg:col-span-5 space-y-5 sm:space-y-6 w-full min-w-0">
                            
                            <div class="bg-gradient-to-br from-brand-purple to-indigo-600 rounded-2xl sm:rounded-3xl p-5 sm:p-8 shadow-lg flex flex-col relative overflow-hidden h-max w-full">
                                <div class="absolute -bottom-10 -right-10 w-24 h-24 sm:w-40 sm:h-40 bg-white opacity-5 rounded-full blur-xl sm:blur-2xl"></div>
                                <span class="text-[7px] sm:text-[9px] font-bold bg-white/20 text-white px-2 sm:px-3 py-0.5 sm:py-1 rounded-full w-max mb-3 sm:mb-6 uppercase tracking-wider">Текущий квартал</span>
                                <h3 class="text-lg sm:text-2xl font-bold mb-2 sm:mb-4 relative z-10 text-white">Видение на 12 недель</h3>
                                <textarea id="vision12Weeks" class="auto-resize vision-input w-full bg-transparent text-white placeholder:text-white/50 resize-none text-xs sm:text-base font-medium leading-relaxed relative z-10 min-h-[5rem] sm:min-h-[8rem] outline-none hover:bg-white/5 focus:bg-white/10 focus:ring-2 focus:ring-white/30 rounded-lg sm:rounded-xl p-2 sm:p-3 -mx-2 sm:-mx-3 transition-all break-words" placeholder="Главные достижения этого квартала..."></textarea>
                                <div class="mt-4 sm:mt-6 pt-3 sm:pt-6 border-t border-white/20 relative z-10 w-full">
                                    <div class="flex justify-between items-end mb-1.5 sm:mb-2 w-full">
                                        <p class="text-[8px] sm:text-[10px] text-white/70 uppercase tracking-wider font-semibold truncate" id="visionBlockProgressText">Прогресс: 0%</p>
                                    </div>
                                    <div class="h-1 sm:h-1.5 w-full bg-white/20 rounded-full overflow-hidden">
                                        <div id="visionBlockProgress" class="h-full bg-emerald-400 transition-all duration-1000" style="width: 0%"></div>
                                    </div>
                                </div>
                            </div>

                            <div class="bg-white rounded-2xl sm:rounded-3xl p-5 sm:p-8 shadow-[0_2px_10px_rgba(0,0,0,0.02)] border border-slate-100 flex flex-col gap-1.5 sm:gap-2 relative overflow-hidden h-max w-full">
                                <h3 class="text-base sm:text-xl font-bold text-slate-800 mb-1 sm:mb-2 relative z-10">Долгосрочное видение</h3>
                                <textarea id="visionLong" class="auto-resize vision-input w-full bg-transparent text-slate-800 text-xs sm:text-base leading-relaxed resize-none placeholder:text-slate-300 relative z-10 min-h-[6rem] sm:min-h-[10rem] outline-none hover:bg-slate-50 focus:bg-slate-50 focus:ring-2 focus:ring-brand-purple/20 rounded-lg sm:rounded-xl p-2 sm:p-4 -mx-2 sm:-mx-4 transition-all break-words" placeholder="«К 2028 году я создал...»"></textarea>
