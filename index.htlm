                            <div class="bg-white rounded-2xl sm:rounded-3xl p-5 sm:p-8 shadow-[0_2px_10px_rgba(0,0,0,0.02)] border border-slate-100 h-max w-full">
                                <h3 class="text-sm sm:text-lg font-bold text-slate-800 mb-3 sm:mb-5 flex items-center"><span class="text-rose-400 mr-1.5 sm:mr-2 text-lg sm:text-xl">⚓</span> Эмоциональные якори</h3>
                                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4 h-full w-full" id="visionAnchorsContainer"></div>
