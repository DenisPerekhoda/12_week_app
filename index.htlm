                            </div>
                            
                            <button id="btnSaveProfile" class="w-full bg-brand-purple text-white rounded-xl py-3 sm:py-4 text-xs sm:text-sm font-bold hover:bg-indigo-700 transition-colors shadow-md mt-2 sm:mt-4 flex items-center justify-center">
                                <span class="mr-1.5 sm:mr-2">💾</span> Сохранить изменения
                            </button>
